# 生产环境配置（复制到服务器 backend-nest 目录为 .env）
# copy .env.production.example .env
# 然后把下面带「请修改」的项改成真实值

# ── MySQL（宝塔 → 数据库，请修改用户名/密码/库名）──
DATABASE_URL="mysql://tapnow:请修改数据库密码@127.0.0.1:3306/tapnow"

# ── JWT（请修改为一串随机密钥，至少 32 位）──
JWT_SECRET=请修改为一串随机密钥至少32位字符
JWT_EXPIRES_IN=7d

# ── Google OAuth（与前端 .env.production 的 VITE_GOOGLE_CLIENT_ID 一致）──
GOOGLE_CLIENT_ID=1018392015490-n2sfvkdfllmeh24p0ddvjrikevfp8enl.apps.googleusercontent.com
GOOGLE_VERIFY_TIMEOUT_MS=30000

# 国内服务器必填：本机 HTTP 代理（Clash / V2Ray 等），用于后端向 Google 验证 ID Token
# 示例：服务器上 Clash 开「允许局域网连接」且 HTTP 端口 7890
GOOGLE_HTTP_PROXY=http://127.0.0.1:7890

# ── 服务 ──
PORT=3000
# CORS：必须与用户浏览器访问前端的地址一致（上 HTTPS 后改成 https）
FRONTEND_URL=https://www.tapnowone.top

# ── 阿里云百炼（Agent 对话 / 分镜）──
DASHSCOPE_API_KEY=sk-your-key-here
DASHSCOPE_MODEL=qwen-plus
