# MySQL（Navicat 本地 test 库）
DATABASE_URL="mysql://root:root@localhost:3306/test"

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d

# Google OAuth（Google Cloud Console → APIs & Services → Credentials）
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# 验证 Google ID Token 超时（毫秒），国内网络慢可适当调大
GOOGLE_VERIFY_TIMEOUT_MS=15000

# 服务端口
PORT=3000
FRONTEND_URL=http://localhost:5173

# 阿里云百炼（DashScope）— Agent 对话 / 分镜 / 文生图
# 控制台：https://bailian.console.aliyun.com/
# 换 Key / 换其他平台说明：docs/AI-PROVIDER.md
DASHSCOPE_API_KEY=sk-ws-H.RXLHDDI****Pefew0gUKUlm3Fg
# 可选模型：qwen-plus / qwen-turbo / qwen-max 等
DASHSCOPE_MODEL=qwen-plus
# 文生图 API 根路径（可换成 Workspace 专属域名）
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# HappyHorse 视频生成（华北2 北京 Workspace MaaS 域名，替换为你的业务空间 URL）
# DASHSCOPE_VIDEO_BASE_URL=https://llm-q7cqck0h4x1ffqdz.cn-beijing.maas.aliyuncs.com/api/v1
# 生图分辨率 width*height，默认 1328*1328
# IMAGE_SIZE=1328*1328
# 拼上游相对图片 URL 用（如 /uploads/...）
# PUBLIC_BASE_URL=http://127.0.0.1:3000

# 火山方舟（DeepSeek 文本 / Seedream 图片 / Seedance 视频）
# 请使用控制台新建的 Key；不要把真实 Key 提交到 Git。
ARK_API_KEY=ark-请使用控制台新建的Key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_REQUEST_TIMEOUT_MS=120000
# VIDEO_RESOLUTION=720p
# VIDEO_RATIO=16:9
# VIDEO_POLL_INTERVAL_MS=8000
# VIDEO_POLL_MAX_ATTEMPTS=150

# 天翼云对象存储（S3 兼容）— 画布/生成物
# 桶保持「私有」；上传预签名；对象设 public-read；用默认 HTTPS 域名联调（备案中可用）
# CTYUN_AK=
# CTYUN_SK=
# CTYUN_BUCKET=bucket-220430
# CTYUN_ENDPOINT=https://huadong-1.ctyunzos.cn
# CTYUN_PUBLIC_BASE=https://bucket-220430.huadong-1.ctyunzos.cn
# CTYUN_REGION=huadong-1
# CTYUN_FORCE_PATH_STYLE=false
# 合成允许的远程媒体域名（逗号分隔）
# COMPOSE_REMOTE_HOSTS=bucket-220430.huadong-1.ctyunzos.cn

# 本地 FFmpeg 动态合成（默认从 PATH 查找）
# FFMPEG_PATH=ffmpeg

# 国内开发/生产：后端验证 Google Token 需能访问 Google API
# 方式一（推荐）：在 .env 写死代理
# GOOGLE_HTTP_PROXY=http://127.0.0.1:7890
# 方式二：npm run start:dev:proxy
# 方式三：HTTP_PROXY=http://127.0.0.1:7890 HTTPS_PROXY=http://127.0.0.1:7890 npm run start:dev
# Clash 默认 7890；Surge 常见 6152；以你的客户端「HTTP 代理端口」为准
