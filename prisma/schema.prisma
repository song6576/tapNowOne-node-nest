generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique @db.VarChar(255)
  phone      Int?     @map("iphone")
  password   String?  @map("passWord") @db.VarChar(255)
  token      String?  @db.VarChar(255)
  googleId   String?  @unique @map("google_id") @db.VarChar(255)
  name       String?  @db.VarChar(255)
  avatarUrl  String?  @map("avatar_url") @db.VarChar(512)
  bannerUrl  String?  @map("banner_url") @db.VarChar(512)
  bio        String?  @db.VarChar(500)
  socialLink String?  @map("social_link") @db.VarChar(512)
  country    String?  @db.VarChar(64)
  city       String?  @db.VarChar(64)
  profession String?  @db.VarChar(128)
  showJoinDate Boolean @default(true) @map("show_join_date")
  tapiesBalance Int    @default(0) @map("tapies_balance")
  activeTeamId  String? @map("active_team_id") @db.Char(36)
  createTime DateTime @default(now()) @map("createTime")

  agentConversations AgentConversation[]
  workspaceFolders   WorkspaceFolder[]
  projects           Project[]
  taptvWorks         TapTVWork[]
  taptvLikes         TapTVLike[]
  taptvFavorites     TapTVFavorite[]
  followers          UserFollow[] @relation("UserFollowers")
  following          UserFollow[] @relation("UserFollowing")
  ownedTeams         Team[]           @relation("TeamOwner")
  teamMemberships    TeamMember[]
  createdInviteLinks TeamInviteLink[] @relation("InviteLinkCreator")
  activeTeam         Team?            @relation("ActiveTeam", fields: [activeTeamId], references: [id], onDelete: SetNull)
  subscriptions      UserSubscription[]
  redemptionRecords  RedemptionRecord[]
  tapiesLedger       TapiesLedger[]
  createdRedemptionCodes RedemptionCode[] @relation("RedemptionCodeCreator")
  generationTasks    GenerationTask[]
  mediaFavorites     UserMediaFavorite[]

  @@map("user")
}

model WorkspaceFolder {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    Int      @map("user_id")
  teamId    String?  @map("team_id") @db.Char(36)
  parentId  String?  @map("parent_id") @db.Char(36)
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  team     Team?             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  parent   WorkspaceFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children WorkspaceFolder[] @relation("FolderTree")
  projects Project[]

  @@index([userId, teamId, updatedAt])
  @@index([teamId, updatedAt])
  @@map("workspace_folder")
}

model Project {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    Int      @map("user_id")
  teamId    String?  @map("team_id") @db.Char(36)
  folderId  String?  @map("folder_id") @db.Char(36)
  name      String   @db.VarChar(255)
  data      String   @db.LongText
  thumbnail String?  @db.VarChar(512)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  team               Team?                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  folder             WorkspaceFolder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)
  agentConversations AgentConversation[]

  @@index([userId, teamId, updatedAt])
  @@index([teamId, updatedAt])
  @@index([folderId])
  @@map("project")
}

model AgentConversation {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    Int      @map("user_id")
  projectId String?  @map("project_id") @db.Char(36)
  title     String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project  Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages AgentMessage[]

  @@index([userId, updatedAt])
  @@index([projectId, updatedAt])
  @@index([userId, projectId])
  @@map("agent_conversation")
}

model AgentMessage {
  id             String   @id @default(uuid()) @db.Char(36)
  conversationId String   @map("conversation_id") @db.Char(36)
  role           String   @db.VarChar(20)
  content        String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(0)

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("agent_message")
}

model FeaturedBanner {
  id        String   @id @default(uuid()) @db.Char(36)
  title     String   @db.VarChar(255)
  subtitle  String?  @db.VarChar(255)
  cover     String   @db.VarChar(512)
  link      String?  @db.VarChar(512)
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  @@index([active, sortOrder])
  @@map("featured_banner")
}

/// TapTV 社区作品。cover=列表封面，videoUrl=悬浮播放地址。详见 docs/SQL.md §7
model TapTVWork {
  id           String   @id @default(uuid()) @db.Char(36)
  userId       Int?     @map("user_id") /// 发布者；种子数据可为空
  title        String   @db.VarChar(255)
  authorName   String   @map("author_name") @db.VarChar(128)
  authorAvatar String   @map("author_avatar") @db.VarChar(16)
  cover        String   @db.VarChar(512) /// 列表默认封面：图片 URL 或 CSS 渐变
  videoUrl     String   @map("video_url") @db.VarChar(512) /// 卡片鼠标悬浮时播放
  description  String?  @db.Text
  producer     String?  @db.VarChar(255)
  forks        Int      @default(0)
  likes        Int      @default(0) /// 冗余计数，与 TapTVLike 同步
  favorites    Int      @default(0) /// 冗余计数，与 TapTVFavorite 同步
  shares       Int      @default(0)
  tags         String   @db.VarChar(512)
  nodeCount    Int      @default(0) @map("node_count")
  category     String   @db.VarChar(32)
  featured     Boolean  @default(false)
  workflowData String?  @map("workflow_data") @db.LongText
  publishedAt  DateTime @map("published_at") @db.DateTime(0)
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  likesList TapTVLike[]
  favList   TapTVFavorite[]

  @@index([featured, publishedAt])
  @@index([category, publishedAt])
  @@index([publishedAt])
  @@index([likes])
  @@map("taptv_work")
}

/// 用户点赞记录；(userId, workId) 唯一 → POST /api/taptv/:id/like
model TapTVLike {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    Int      @map("user_id")
  workId    String   @map("work_id") @db.Char(36)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  work TapTVWork @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
  @@index([workId])
  @@map("taptv_like")
}

/// 用户收藏记录；(userId, workId) 唯一 → POST favorite / GET favorites
model TapTVFavorite {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    Int      @map("user_id")
  workId    String   @map("work_id") @db.Char(36)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  work TapTVWork @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
  @@index([workId])
  @@map("taptv_favorite")
}

/// 画布素材收藏（视频/图片）；个人主页「我的收藏」与 TapTV 收藏一并展示
model UserMediaFavorite {
  id           String   @id @default(uuid()) @db.Char(36)
  userId       Int      @map("user_id")
  mediaUrl     String   @map("media_url") @db.VarChar(1024)
  mediaUrlHash String   @map("media_url_hash") @db.VarChar(64)
  mediaType    String   @map("media_type") @db.VarChar(16) /// video | image
  title        String?  @db.VarChar(255)
  coverUrl     String?  @map("cover_url") @db.VarChar(1024)
  projectId    String?  @map("project_id") @db.Char(36)
  nodeId       String?  @map("node_id") @db.VarChar(64)
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaUrlHash])
  @@index([userId, createdAt])
  @@map("user_media_favorite")
}

model UserFollow {
  id          String   @id @default(uuid()) @db.Char(36)
  followerId  Int      @map("follower_id")
  followingId Int      @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(0)

  follower  User @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("user_follow")
}

model Team {
  id            String   @id @default(uuid()) @db.Char(36)
  publicId      String   @unique @map("public_id") @db.VarChar(32)
  name          String   @db.VarChar(255)
  ownerId       Int      @map("owner_id")
  tapiesBalance Int      @default(0) @map("tapies_balance")
  createdAt     DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  owner        User              @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      TeamMember[]
  inviteLinks  TeamInviteLink[]
  folders      WorkspaceFolder[]
  projects     Project[]
  activeUsers  User[]            @relation("ActiveTeam")
  subscriptions UserSubscription[]
  redemptionRecords RedemptionRecord[]
  tapiesLedger TapiesLedger[]

  @@index([ownerId])
  @@map("team")
}

model TeamMember {
  id           String   @id @default(uuid()) @db.Char(36)
  teamId       String   @map("team_id") @db.Char(36)
  userId       Int      @map("user_id")
  role         String   @default("member") @db.VarChar(20)
  inviteLinkId String?  @map("invite_link_id") @db.Char(36)
  quotaLimit   Int?     @map("quota_limit")
  quotaUsed    Int      @default(0) @map("quota_used")
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(0)

  team       Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  inviteLink TeamInviteLink? @relation(fields: [inviteLinkId], references: [id], onDelete: SetNull)

  @@unique([teamId, userId])
  @@index([userId])
  @@index([inviteLinkId])
  @@map("team_member")
}

model TeamInviteLink {
  id             String    @id @default(uuid()) @db.Char(36)
  teamId         String    @map("team_id") @db.Char(36)
  token          String    @unique @db.VarChar(32)
  createdBy      Int       @map("created_by")
  expiresAt      DateTime  @map("expires_at") @db.DateTime(0)
  maxUses        Int?      @map("max_uses")
  useCount       Int       @default(0) @map("use_count")
  unlimitedQuota Boolean   @default(true) @map("unlimited_quota")
  revokedAt      DateTime? @map("revoked_at") @db.DateTime(0)
  createdAt      DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.DateTime(0)

  team    Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  creator User         @relation("InviteLinkCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  members TeamMember[]

  @@index([teamId])
  @@index([expiresAt])
  @@map("team_invite_link")
}

/// 用户/团队订阅。teamId 为空=个人订阅
model UserSubscription {
  id        String    @id @default(uuid()) @db.Char(36)
  userId    Int       @map("user_id")
  teamId    String?   @map("team_id") @db.Char(36)
  planSlug  String    @map("plan_slug") @db.VarChar(32)
  cycle     String    @db.VarChar(16)
  proTapies Int?      @map("pro_tapies")
  status    String    @default("active") @db.VarChar(16)
  startedAt DateTime  @map("started_at") @db.DateTime(0)
  expiresAt DateTime? @map("expires_at") @db.DateTime(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.DateTime(0)

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([teamId])
  @@map("user_subscription")
}

/// 礼包超市商品
model GiftPack {
  id             String   @id @default(uuid()) @db.Char(36)
  modelName      String   @map("model_name") @db.VarChar(64)
  tier           String   @db.VarChar(32)
  priceUsdCents  Int      @map("price_usd_cents")
  tapiesAmount   Int      @map("tapies_amount")
  tapiesLabel    String   @map("tapies_label") @db.VarChar(128)
  bgGradient     String   @map("bg_gradient") @db.VarChar(256)
  stockTotal     Int      @default(100) @map("stock_total")
  stockRemaining Int      @default(100) @map("stock_remaining")
  sortOrder      Int      @default(0) @map("sort_order")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  @@index([active, sortOrder])
  @@map("gift_pack")
}

/// 兑换码
model RedemptionCode {
  id           String    @id @default(uuid()) @db.Char(36)
  code         String    @unique @db.VarChar(64)
  activityName String    @map("activity_name") @db.VarChar(255)
  tapiesAmount Int       @map("tapies_amount")
  maxUses      Int       @default(1) @map("max_uses")
  usedCount    Int       @default(0) @map("used_count")
  expiresAt    DateTime? @map("expires_at") @db.DateTime(0)
  createdBy    Int?      @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(0)

  creator User?              @relation("RedemptionCodeCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  records RedemptionRecord[]

  @@index([expiresAt])
  @@map("redemption_code")
}

/// 兑换记录
model RedemptionRecord {
  id           String   @id @default(uuid()) @db.Char(36)
  codeId       String   @map("code_id") @db.Char(36)
  userId       Int      @map("user_id")
  teamId       String?  @map("team_id") @db.Char(36)
  codeDisplay  String   @map("code_display") @db.VarChar(64)
  activityName String   @map("activity_name") @db.VarChar(255)
  tapiesAmount Int      @map("tapies_amount")
  redeemedAt   DateTime @default(now()) @map("redeemed_at") @db.DateTime(0)

  code RedemptionCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([userId, redeemedAt])
  @@map("redemption_record")
}

/// Tapies 流水
model TapiesLedger {
  id            String   @id @default(uuid()) @db.Char(36)
  userId        Int      @map("user_id")
  teamId        String?  @map("team_id") @db.Char(36)
  type          String   @db.VarChar(32)
  amount        Int
  balanceAfter  Int      @map("balance_after")
  description   String   @db.VarChar(512)
  refType       String?  @map("ref_type") @db.VarChar(32)
  refId         String?  @map("ref_id") @db.Char(36)
  operatorEmail String?  @map("operator_email") @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at") @db.DateTime(0)

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([teamId, createdAt])
  @@map("tapies_ledger")
}

/// AI 模型目录：按 text / image / video / audio 分类，供首页与画布节点选用
model AiModel {
  id           String   @id @default(uuid()) @db.Char(36)
  slug         String   @unique @db.VarChar(64)
  provider     String   @default("dashscope") @db.VarChar(32)
  providerModelId String @map("provider_model_id") @db.VarChar(128)
  label        String   @db.VarChar(128)
  category     String   @db.VarChar(16)
  description  String   @db.Text
  usageHint    String?  @map("usage_hint") @db.VarChar(512)
  icon         String   @default("·") @db.VarChar(8)
  tier         String?  @db.VarChar(16)
  isPremium    Boolean  @default(false) @map("is_premium")
  isComingSoon Boolean  @default(false) @map("is_coming_soon")
  nodeTypes    String   @map("node_types") @db.VarChar(128)
  sortOrder    Int      @default(0) @map("sort_order")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  @@index([category, active, sortOrder])
  @@map("ai_model")
}

/// AI 生成/合成任务：跨进程保存方舟长任务及 FFmpeg 导出状态
model GenerationTask {
  id             String   @id @default(uuid()) @db.Char(36)
  userId         Int      @map("user_id")
  kind           String   @db.VarChar(16)
  nodeType       String?  @map("node_type") @db.VarChar(16)
  provider       String?  @db.VarChar(32)
  providerTaskId String?  @map("provider_task_id") @db.VarChar(128)
  state          String   @default("pending") @db.VarChar(16)
  progress       Int      @default(0)
  resultUrl      String?  @map("result_url") @db.VarChar(1024)
  error          String?  @db.Text
  metadata       String?  @db.LongText
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.DateTime(0)
  expiresAt      DateTime @map("expires_at") @db.DateTime(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([state, expiresAt])
  @@map("generation_task")
}
